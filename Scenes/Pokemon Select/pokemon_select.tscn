[sub_resource type="GDScript" id="GDScript_ex2ck"]
script/source = "extends Control

@onready var pokemon_list = get_node_or_null(\"MarginContainer/VBoxContainer/PokemonList\")
@onready var confirm_button = get_node_or_null(\"MarginContainer/VBoxContainer/ConfirmButton\")
@onready var music: AudioStreamPlayer2D = $SelectMusic
@onready var fade: ColorRect = $Fade

var selected_option = null

func _ready():
	
	fade.modulate.a = 1.0

	var tween = create_tween()
	tween.tween_property(fade, \"modulate:a\", 0.0, 1)

	print(\"DEBUG pokemon_list:\", pokemon_list)
	print(\"DEBUG confirm_button:\", confirm_button)

	if music:
		music.play()

	if confirm_button == null:
		push_error(\"ConfirmButton no encontrado.\")
		return

	if pokemon_list == null:
		push_error(\"PokemonList no encontrado.\")
		return

	confirm_button.disabled = true

	load_pokemon()

func load_pokemon():

	var species_list = [
		load(\"res://Data/GodotResources/Species/BULBASAUR.tres\"),
		load(\"res://Data/GodotResources/Species/CHARMANDER.tres\"),
		load(\"res://Data/GodotResources/Species/SQUIRTLE.tres\")
	]

	var option_scene = preload(\"res://Scenes/pokemon_option.tscn\")

	for species in species_list:

		if species == null:
			continue

		var option = option_scene.instantiate()

		pokemon_list.add_child(option) # PRIMERO se agrega al árbol

		option.setup(species) # DESPUÉS se configura

		option.connect(\"pokemon_selected\", Callable(self, \"_on_pokemon_selected\"))

func _on_pokemon_selected(option):

	selected_option = option

	for child in pokemon_list.get_children():
		child.modulate = Color(1,1,1)
		child.scale = Vector2(1,1)

	option.modulate = Color(1,1,0.6)
	option.scale = Vector2(1.2,1.2)

	confirm_button.disabled = false

func _on_ConfirmButton_pressed():

	if selected_option == null:
		return

	print(\"Pokemon elegido:\", selected_option.species.id)

	var tween = create_tween()
	tween.tween_property(fade, \"modulate:a\", 1.0, 0.6)
	await tween.finished

	if music:
		music.stop()

	# Cargar escena de batalla
	var battle_scene = load(\"res://Scenes/Battle/BattleScene.tscn\").instantiate()

	# Crear equipos
	var player_team = OpTeam.new()
	var opponent_team = OpTeam.new()


	
	# Crear Pokémon del jugador
	var player_mon = OpMon.new()
	player_mon.species = selected_option.species
	player_mon.level = 5
	player_mon.calc_stats()
	player_mon.learn_initial_moves()
	player_mon.heal()
	player_team.add_opmon(player_mon)

	# Iniciales posibles
	var starters = [
		load(\"res://Data/GodotResources/Species/BULBASAUR.tres\"),
		load(\"res://Data/GodotResources/Species/CHARMANDER.tres\"),
		load(\"res://Data/GodotResources/Species/SQUIRTLE.tres\")
	]

	# Rival recibe los que NO elegiste
	for species in starters:
		if species != selected_option.species:
			var enemy_mon = OpMon.new()
			enemy_mon.species = species
			enemy_mon.level = 5
			enemy_mon.calc_stats()
			enemy_mon.learn_initial_moves()
			enemy_mon.heal()
			opponent_team.add_opmon(enemy_mon)

	# Inicializar batalla
	print(\"PLAYER TEAM SIZE:\", player_team.size())
	print(\"OPPONENT TEAM SIZE:\", opponent_team.size())
	
	battle_scene.init(player_team, opponent_team)

	# Cambiar escena
	get_tree().root.add_child(battle_scene)
	queue_free()
"

